{
    "name": "cainydev/laragraph",
    "description": "Build stateful, multi-agent LLM workflows in Laravel. Adapts LangGraph’s cyclic graphs for PHP’s stateless architecture with built-in persistence. ",
    "keywords": [
        "cainy",
        "laravel",
        "laragraph"
    ],
    "homepage": "https://github.com/cainydev/laragraph",
    "license": "MIT",
    "authors": [
        {
            "name": "John Wagner",
            "email": "wajo432@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.4",
        "illuminate/contracts": "^11.0||^12.0||^13.0",
        "spatie/laravel-package-tools": "^1.16",
        "symfony/expression-language": "^8.0"
    },
    "require-dev": {
        "laravel/ai": "^0.3.2",
        "prism-php/prism": "^0.99|^0.100",
        "inertiajs/inertia-laravel": "^3.0",
        "laravel/reverb": "^1.0",
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.14",
        "nunomaduro/collision": "^8.8",
        "orchestra/testbench": "^10.11||^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Cainy\\Laragraph\\": "src/",
            "Cainy\\Laragraph\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Cainy\\Laragraph\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/",
            "Workbench\\Database\\Factories\\": "workbench/database/factories/",
            "Workbench\\Database\\Seeders\\": "workbench/database/seeders/"
        },
        "files": [
            "tests/Helpers.php"
        ]
    },
    "scripts": {
        "post-autoload-dump": [
            "@clear",
            "@prepare",
            "@composer run prepare"
        ],
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint",
        "clear": "@php vendor/bin/testbench package:purge-skeleton --ansi",
        "build": "@php vendor/bin/testbench workbench:build --ansi",
        "serve": [
            "Composer\\Config::disableProcessTimeout",
            "@build",
            "npx --prefix workbench concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"vendor/bin/testbench serve\" \"vendor/bin/testbench queue:listen --tries=3 --timeout=0\" \"vendor/bin/testbench reverb:start\" \"npm run dev --prefix workbench\" --names=server,queue,reverb,vite --kill-others"
        ],
        "lint": [
            "@php vendor/bin/pint --ansi",
            "@php vendor/bin/phpstan analyse --verbose --ansi"
        ]
    },
    "suggest": {
        "laravel/ai": "Required to use the Laragraph Laravel AI integration traits.",
        "prism-php/prism": "Required to use PrismNode and ToolNode."
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Cainy\\Laragraph\\LaragraphServiceProvider"
            ],
            "aliases": {
                "Laragraph": "Cainy\\Laragraph\\Facades\\Laragraph"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
